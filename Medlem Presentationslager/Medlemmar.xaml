<Window x:Class="Medlem_Presentationslager.Medlemmar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Medlem_Presentationslager"
        xmlns:vm="clr-namespace:Medlem_Presentationslager.ViewModel"
        Title="Samverket - medlemmar" Height="500" Width="750"
        x:Name="MedlemWindow"
        WindowStartupLocation="CenterScreen" Background="{StaticResource HuvudBakgrund}">

    <Window.Resources>
        <local:ByteToImageConverter x:Key="ByteToImageConverter"/>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Våra Medlemmar" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Här kan du se andra som är en del av Samverket" FontSize="14" Opacity="0.7" HorizontalAlignment="Center"/>
        </StackPanel>

        <DataGrid x:Name="MedlemsGrid" Grid.Row="1" 
          ItemsSource="{Binding Medlemmar}"
          AutoGenerateColumns="False" 
          IsReadOnly="True" 
          Background="White"          
          AlternatingRowBackground="#FFF1F1F1"
          BorderBrush="HotPink"
          BorderThickness="1"
          CanUserAddRows="False">

            <DataGrid.Columns>

                <DataGridTemplateColumn Header="Profilbild" Width="110">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="{Binding Profilbild, Converter={StaticResource ByteToImageConverter}}" 
                               Width="50" 
                               Height="50" 
                               Stretch="UniformToFill"
                               Margin="4">
                                    <Image.Clip>
                                        <EllipseGeometry Center="25,25" RadiusX="25" RadiusY="25" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Namn" Binding="{Binding Namn}" Width="*"/>
                <DataGridTextColumn Header="Nivå" Binding="{Binding Medlemsnivå}" Width="100"/>
                <DataGridTextColumn Header="E-post" Binding="{Binding Epost}" Width="200"/>
                <DataGridTextColumn Header="Poäng" Binding="{Binding Poäng}" Width="80"/>

            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Tillbaka till menyn" Grid.Row="2" 
                Width="200" Height="40" 
                Margin="0,20,0,0"
                HorizontalAlignment="Left"
                Background="LightGray" BorderBrush="HotPink" BorderThickness="1"
                Cursor="Hand" Command="{Binding TillbakaCommand}"
                CommandParameter="{Binding ElementName=MedlemWindow}"/>
    </Grid>
</Window>