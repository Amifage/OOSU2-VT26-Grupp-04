<Window x:Class="Medlem_Presentationslager.MenyMedlem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Medlem_Presentationslager.ViewModel"
        Title="Meny" Height="600" Width="900"
        x:Name="MenyWindow"
        WindowStartupLocation="CenterScreen" Background="{StaticResource HuvudBakgrund}">
 


    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="Meny" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Vad vill du göra idag?" FontSize="16" Opacity="0.7" HorizontalAlignment="Center"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2" Margin="10">

            <Button Margin="5" Background="White" Cursor="Hand" x:Name="btnNyBokning" Command="{Binding SkapaBokningCommand}">
                <StackPanel>
                    <TextBlock Text="📅" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Skapa ny bokning" FontSize="18" FontWeight="Bold" Margin="5"/>
                    <TextBlock Text="Hitta lediga tider och boka" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </Button>

            <Button Margin="5" Background="White" Cursor="Hand" x:Name="btnMinaSidor" CommandParameter="{Binding ElementName=MenyWindow}" Command="{Binding MinaSidorCommand}">
                <StackPanel>
                    <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Se mina sidor" FontSize="18" FontWeight="Bold" Margin="5"/>
                    <TextBlock Text="Hantera din profil" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </Button>

            <Button Margin="5" Background="White" Cursor="Hand" x:Name="btnUppdatera" Command="{Binding MinaSidorCommand}">
                <StackPanel>
                    <TextBlock Text="✏️" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ändra/Avboka" FontSize="18" FontWeight="Bold" Margin="5"/>
                    <TextBlock Text="Se dina aktuella bokningar" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </Button>

            <Button Margin="5" Background="White" Cursor="Hand" x:Name="btnHistorik" Command="{Binding AndraAvbokaCommand}">
                <StackPanel>
                    <TextBlock Text="📜" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Bokningshistorik" FontSize="18" FontWeight="Bold" Margin="5"/>
                    <TextBlock Text="Se tidigare bokningar" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </Button>

            <Button Margin="5" Background="White" Cursor="Hand" x:Name="btnAndraMedlemmar" Command="{Binding MedlemarCommand}"
            CommandParameter="{Binding ElementName=MenyWindow}">
                <StackPanel>
                    <TextBlock Text="👥" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Medlemmar" FontSize="18" FontWeight="Bold" Margin="5"/>
                    <TextBlock Text="Se andra som är med i Samverket" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </Button>

        </UniformGrid>

        <Button Grid.Row="2" Content="Logga ut" Width="150" Height="40" 
                Background="#FFD8997C" Margin="0,20,0,0"
                HorizontalAlignment="Right" x:Name="btnLoggaUt"
           Command="{Binding LoggaUtCommand}"
            CommandParameter="{Binding ElementName=MenyWindow}"/>
    </Grid>
</Window>