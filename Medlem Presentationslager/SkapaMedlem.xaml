<Window x:Class="Medlem_Presentationslager.SkapaMedlem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bli Medlem" Height="750" Width="500"
        x:Name="SkapNyMedlem"
        WindowStartupLocation="CenterScreen" Background="{StaticResource HuvudBakgrund}">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Registrera nytt konto" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Fullständigt namn" Margin="0,10,0,5" FontWeight="Bold"/>
                <TextBox x:Name="NamnTextBox" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>

                <TextBlock Text="E-postadress" Margin="0,15,0,5" FontWeight="Bold"/>
                <TextBox x:Name="EpostTextBox" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>

                <TextBlock Text="Telefonnummer" Margin="0,15,0,5" FontWeight="Bold"/>
                <TextBox x:Name="TelefonTextBox" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>

                <TextBlock Text="Välj Medlemsnivå" Margin="0,15,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="NivaComboBox" Height="35">
                    <ComboBoxItem Content="Företag"/>
                    <ComboBoxItem Content="Fast"/>
                    <ComboBoxItem Content="Flex"/>
                </ComboBox>

                <TextBlock Text="Har du betalat på plats?" Margin="0,15,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="BetalstatusComboBox" Height="35">
                    <ComboBoxItem Content="Betald"/>
                    <ComboBoxItem Content="Obetald"/>
                </ComboBox>

                <TextBlock Text="Välj lösenord" Margin="0,15,0,5" FontWeight="Bold"/>
                <TextBox x:Name="LosenordTextBox" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <Button x:Name="SparaButton" Content="Skapa konto" Height="45" Background="HotPink" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="AvbrytButton" Content="Avbryt" Margin="0,10,0,0" Background="LightGray" BorderThickness="1"  Command="{Binding TillbakaCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>