<Window x:Class="Medlem_Presentationslager.MedlemLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medlem - Logga in" Height="500" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⭐" FontSize="60" HorizontalAlignment="Center" />

        <StackPanel Grid.Row="1" Margin="0,0,0,30">
            <TextBlock Text="Medlemsinloggning" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Ange dina uppgifter för att fortsätta" FontSize="13" Foreground="#FF636363" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" VerticalAlignment="Center">
            <TextBlock Text="E-postadress" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,20">
                <TextBox x:Name="EmailTextBox" Height="40" Padding="10,8" Background="White" BorderThickness="0"/>
            </Border>

            <TextBlock Text="Lösenord" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                <PasswordBox x:Name="PasswordBox" Height="40" Padding="10,8" Background="White" BorderThickness="0"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <Button Content="Logga in" Height="45" Background="HotPink" Foreground="White" FontWeight="Bold" />

            <Button Content="Har du inget konto? Registrera dig här" 
            Margin="0,15,0,0" 
            Background="Transparent" 
            BorderThickness="0" 
            Foreground="#FF2980B9" 
            Cursor="Hand"/>

            <Button Content="Tillbaka" 
                    Margin="0,10,0,0" 
                    Background="LightGray"
                    BorderThickness="1" 
                    Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>