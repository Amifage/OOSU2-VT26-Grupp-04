<Window x:Class="Medlem_Presentationslager.MinaSidor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mina Sidor" Height="850" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <!--<Ellipse x:Name="ProfilBildCirkel" Width="100" Height="100" Stroke="HotPink" StrokeThickness="2">
                <Ellipse.Fill>
                    <ImageBrush x:Name="ProfilBildBrush" ImageSource="/Images/default_user.png" Stretch="UniformToFill"/>
                </Ellipse.Fill>
            </Ellipse>-->
            <Button Content="Byt profilbild" Margin="0,5,0,0"
                    Background="Transparent" BorderThickness="0" Foreground="#FF2980B9" Cursor="Hand"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Namn" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="NamnTextBox" IsReadOnly="True" Background="#EEEEEE" Height="35" VerticalContentAlignment="Center"/>

                <TextBlock Text="Mina poäng" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox x:Name="PoangTextBox" IsReadOnly="True" Background="#EEEEEE" Height="35" VerticalContentAlignment="Center"/>

                <TextBlock Text="Betalstatus" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox x:Name="BetalstatusTextBox" IsReadOnly="True" Background="#EEEEEE" Height="35" VerticalContentAlignment="Center"/>

                <Separator Margin="0,20" Background="HotPink" Height="1"/>

                <TextBlock Text="Ändra Medlemsnivå" FontWeight="Bold" Margin="0,5,0,5"/>
                <ComboBox x:Name="NivaComboBox" Height="35" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Flex"/>
                    <ComboBoxItem Content="Fast"/>
                    <ComboBoxItem Content="Företag"/>
                </ComboBox>

                <TextBlock Text="Ändra E-postadress" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox x:Name="EpostTextBox" Height="35" Background="White" VerticalContentAlignment="Center"/>

                <TextBlock Text="Ändra Telefonnummer" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox x:Name="TelefonTextBox" Height="35" Background="White" VerticalContentAlignment="Center"/>

                <TextBlock Text="Nytt Lösenord" FontWeight="Bold" Margin="0,15,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="35" Background="White" VerticalContentAlignment="Center"/>
                <TextBlock Text="Lämna tomt om du inte vill byta" FontSize="10" Opacity="0.6"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Tillbaka" Grid.Column="0" Height="45" Margin="0,0,10,0"
                    Background="Transparent" BorderBrush="HotPink" BorderThickness="1" />

            <Button Content="Spara ändringar" Grid.Column="1" Height="45" 
                    Background="HotPink" Foreground="White" FontWeight="Bold" />
        </Grid>
    </Grid>
</Window>