<Window x:Class="Medlem_Presentationslager.MinaSidor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mina Sidor" Height="850" Width="500"
        WindowStartupLocation="CenterScreen" Background="{StaticResource HuvudBakgrund}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Ellipse x:Name="ProfilBildCirkel" Width="100" Height="100" Stroke="HotPink" StrokeThickness="2">
                <Ellipse.Fill>
                    <ImageBrush x:Name="ProfilBildBrush" ImageSource="/Gemini_Generated_Image_rtnq6xrtnq6xrtnq.png" Stretch="UniformToFill"/>
                </Ellipse.Fill>
            </Ellipse>
           
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Namn" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="NamnTextBox" Text="{Binding InloggadMedlem.Namn, Mode=OneWay}" IsReadOnly="True" Background="#EEEEEE" Height="35" VerticalContentAlignment="Center"/>

                <TextBlock Text="Mina poäng" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding InloggadMedlem.Poäng, Mode=OneWay}" IsReadOnly="True" Background="#EEEEEE" Height="35" VerticalContentAlignment="Center"/>
                <TextBlock Text="Betalstatus" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding InloggadMedlem.Betalstatus, Mode=OneWay}" IsReadOnly="True" Background="#EEEEEE" Height="35" VerticalContentAlignment="Center"/>
                <Separator Margin="0,20" Background="HotPink" Height="1"/>

                <TextBlock Text="Ändra Medlemsnivå" FontWeight="Bold" Margin="0,5,0,5"/>
                <ComboBox SelectedValue="{Binding InloggadMedlem.Medlemsnivå}" SelectedValuePath="Content" Height="35" VerticalContentAlignment="Center" ItemsSource="{Binding MedlemsNivåer}"
                              SelectedItem="{Binding MedlemsNivå, Mode=TwoWay}"/>

                <TextBlock Text="Ändra E-postadress" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding InloggadMedlem.Epost, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="White" VerticalContentAlignment="Center"/>
                <TextBlock Text="Ändra Telefonnummer" FontWeight="Bold" Margin="0,15,0,5"/>
<TextBox Text="{Binding InloggadMedlem.Telefonnummer, UpdateSourceTrigger=PropertyChanged}" Height="35" Background="White" VerticalContentAlignment="Center"/>
                <TextBlock Text="Nytt Lösenord" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding NyttLösenord, UpdateSourceTrigger=PropertyChanged}" 
         Height="35" Background="White" VerticalContentAlignment="Center"/>
                <TextBlock Text="Lämna tomt om du inte vill byta" FontSize="10" Opacity="0.6"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Tillbaka" Command="{Binding TillbakaCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Background="LightGray" BorderThickness="1" BorderBrush="HotPink"/>

            <Button Content="Spara ändringar" Command="{Binding SparaÄndringarCommand}" Grid.Column="1" Height="45" 
                    Background="HotPink" Foreground="White" FontWeight="Bold" />
        </Grid>
    </Grid>
</Window>