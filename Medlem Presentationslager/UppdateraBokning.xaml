<Window x:Class="Medlem_Presentationslager.UppdateraBokning"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hantera mina bokningar" Height="850" Width="650"
        WindowStartupLocation="CenterScreen" Background="{StaticResource HuvudBakgrund}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Ändra eller avboka" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <GroupBox Grid.Row="1" Header="Välj bokning att hantera" BorderBrush="HotPink" Margin="0,0,0,15">
            <DataGrid x:Name="MinaBokningarGrid" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Datum" Binding="{Binding StartDatum, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                    <DataGridTextColumn Header="Tid" Binding="{Binding StartDatum, StringFormat=\{0:HH:mm\}}" Width="60"/>
                    <DataGridTextColumn Header="Resurs" Binding="{Binding Resurs.Namn}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" BorderBrush="#FFEB6A98" BorderThickness="1">
            <StackPanel x:Name="EditPanel" IsEnabled="False">
                <TextBlock Text="Redigera vald bokning" FontWeight="Bold" FontSize="18" Margin="0,0,0,15" Foreground="HotPink"/>

                <TextBlock Text="Nytt Datum" Margin="0,10,0,5"/>
                <DatePicker x:Name="NyttDatumPicker" />

                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Ny Starttid" Margin="0,0,0,5"/>
                        <ComboBox x:Name="StartTidCombo" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Ny Sluttid" Margin="0,0,0,5"/>
                        <ComboBox x:Name="SlutTidCombo" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Välj ny resurs (valfritt)" Margin="0,15,0,5"/>
                <ListBox x:Name="LedigaResurserList" Height="80" BorderBrush="HotPink" />

                <TextBlock Text="Anteckning (deltagare, syfte...)" Margin="0,15,0,5" />
                <TextBox x:Name="AnteckningTextBox" 
                         Height="70" 
                         AcceptsReturn="True" 
                         TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto" 
                         Padding="5" 
                         BorderBrush="HotPink"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Tillbaka" Width="100" Height="40" Background="LightGray" BorderBrush="HotPink" BorderThickness="1"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Avboka" Width="120" Height="40" Background="#FFFF8D8D" Margin="0,0,10,0" FontWeight="Bold"/>
                <Button Content="Spara ändringar" Width="150" Height="40" Background="HotPink" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>