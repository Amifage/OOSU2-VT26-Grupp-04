<Window x:Class="Medlem_Presentationslager.NyBokning"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skapa ny bokning" Height="750" Width="600"
        WindowStartupLocation="CenterScreen" Background="{StaticResource HuvudBakgrund}" >
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Skapa bokning" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Margin="10,0">
                    <TextBlock Text="Välj Datum" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DatePicker x:Name="BokningsDatumPicker" Width="150" />
                </StackPanel>

                <StackPanel Margin="10,0">
                    <TextBlock Text="Starttid" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="StartTidCombo" Width="80" />
                </StackPanel>

                <StackPanel Margin="10,0">
                    <TextBlock Text="Sluttid" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="SlutTidCombo" Width="80" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Tillgängliga resurser för vald tid:" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListBox x:Name="LedigaResurserListBox" Height="200" BorderBrush="HotPink" BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="🏢" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Namn}" FontWeight="SemiBold"/>
                            <TextBlock Text=" - "/>
                            <TextBlock Text="{Binding Typ}" FontStyle="Italic"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Anteckningar (deltagare, syfte...)" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="AnteckningTextBox" 
                     Height="80" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" 
                     Padding="5"
                     BorderBrush="HotPink"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Tillbaka" Grid.Column="0" Height="45" Margin="0,0,10,0"
                    Background="LightGray" BorderBrush="HotPink" BorderThickness="1" />

            <Button Content="Bekräfta Bokning" Grid.Column="1" Height="45" 
                    Background="HotPink" Foreground="White" FontWeight="Bold" />
        </Grid>
    </Grid>
</Window>