<Window x:Class="Presentationslager.RapportResurs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resursrapport" Height="650" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Beläggningsrapport" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Visa statistik från:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpStartDatum" Width="150" Margin="0,0,20,0"/>
                <Button x:Name="btnUppdatera" Content="Generera Rapport" Width="130" Height="30" Click="btnUppdatera_Click" 
                        FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,20">
            <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0"  BorderThickness="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="Totalt antal bokningar" Foreground="Gray" FontSize="14"/>
                    <TextBlock x:Name="lblTotaltAntal" Text="0" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0"  BorderThickness="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="Mest bokade resurs" Foreground="Gray" FontSize="14"/>
                    <TextBlock x:Name="lblPopulärastResurs" Text="-" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="5" BorderBrush="#DDD" BorderThickness="1">
            <DataGrid x:Name="dgResursStatistik" AutoGenerateColumns="False" IsReadOnly="True" 
                      GridLinesVisibility="None" Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Resursnamn" Binding="{Binding Namn}" Width="2*"/>
                    <DataGridTextColumn Header="Typ" Binding="{Binding Typ}" Width="*"/>
                    <DataGridTextColumn Header="Antal Bokningar" Binding="{Binding AntalBokningar}" Width="*"/>
                    <DataGridTextColumn Header="Beläggning (%)" Binding="{Binding Belaggningsgrad}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
       
    </Grid>
</Window>